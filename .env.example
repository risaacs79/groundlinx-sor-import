# Required environment variables. Set these in Netlify UI (Site settings → Environment variables).
# Never commit real values. This file is the public template only.

# Monday.com API token with write scope on the SOR Lines, Active Jobs,
# Approved & Paid Jobs, Network Assets, and SOR Sync Audit Log boards.
# Same token used by the main field app's sync scripts (PR #27 / #31).
MONDAY_API_TOKEN=

# Shared password the VA team types into the upload page. Defence-in-depth
# layer on top of the hard-to-guess Netlify subdomain. 32+ random chars
# recommended.
UPLOAD_PASSWORD=

# Monday board id of the "SOR Sync Audit Log" board. Created in
# sub-step 4 of this project. The serverless function posts a row here
# on every upload (success or failure).
AUDIT_BOARD_ID=
